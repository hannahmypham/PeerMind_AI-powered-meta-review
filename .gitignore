# ==========================================================
# Data (DO NOT COMMIT RAW OR PROCESSED DATA)
# ==========================================================
# Ignore everything in data
data/*

# But keep the data folder itself
!data/

# Allow predictions
!data/predictions/
!data/predictions/*.csv

# Allow demo metadata (for Streamlit deploy: paper titles + abstracts)
!data/demo/
!data/demo/*.csv

# Allow top_30 folder
!data/top_30/
!data/top_30/*.csv


